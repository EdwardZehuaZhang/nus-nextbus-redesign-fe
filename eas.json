{
  "cli": {
    "version": ">= 3.8.1",
    "appVersionSource": "remote"
  },
  "build": {
    "production": {
      "channel": "production",
      "distribution": "store",
      "pnpm": "9.12.3",
      "ios": {
        "image": "latest"
      },
      "android": {
        "buildType": "app-bundle",
        "image": "latest"
      },
      "env": {
        "EXPO_NO_DOTENV": "1",
        "APP_ENV": "production",
        "FLIPPER_DISABLE": "1",
        "SENTRY_ALLOW_FAILURE": "true"
      }
    },
    "staging": {
      "channel": "staging",
      "distribution": "internal",
      "pnpm": "9.12.3",
      "ios": {
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "image": "latest"
      },
      "env": {
        "APP_ENV": "staging",
        "EXPO_NO_DOTENV": "1",
        "FLIPPER_DISABLE": "1"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "pnpm": "9.12.3",
      "ios": {
        "image": "latest"
      },
      "android": {
        "image": "latest"
      },
      "env": {
        "APP_ENV": "development",
        "EXPO_NO_DOTENV": "1"
      },
      "channel": "development"
    },
    "adhoc": {
      "channel": "adhoc",
      "distribution": "internal",
      "environment": "production",
      "pnpm": "9.12.3",
      "ios": {
        "simulator": false,
        "image": "latest",
        "buildConfiguration": "Release"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_NO_DOTENV": "1",
        "FLIPPER_DISABLE": "1"
      }
    },
    "simulator": {
      "pnpm": "9.12.3",
      "environment": "production",
      "ios": {
        "simulator": true,
        "image": "latest"
      },
      "android": {
        "image": "latest"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_NO_DOTENV": "1",
        "FLIPPER_DISABLE": "1",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      },
      "channel": "simulator"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6757093050",
        "appleId": "edward.zehua.zhang@gmail.com"
      }
    }
  }
}
